{
  "name": "flx6-obs-visualizer",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "DDJ-FLX6 browser visualizer with host/viewer pages, browser WebMIDI, WebSocket rooms, and an official FLX6 controller layer.",
  "scripts": {
    "start": "node server/server.js",
    "dev": "NODE_ENV=development node server/server.js",
    "dev:list-hid": "node -e \"console.table(require('node-hid').devices().map(d=>({vendorId:'0x'+d.vendorId?.toString(16),productId:'0x'+d.productId?.toString(16),product:d.product})))\"",
    "dev:list-midi": "node -e \"const e=require('easymidi');console.log('Inputs:',e.getInputs());console.log('Outputs:',e.getOutputs());\"",
    "test:room-join": "node --test tests/server-room-join.test.js",
    "test:unit": "node --test tests/*.test.js",
    "test:decode": "node src/testDecode.js",
    "test": "npm run test:unit",
    "test:watch": "nodemon --exec \"node --test tests/*.test.js\""
  },
  "dependencies": {
    "easymidi": "^3.0.1",
    "express": "^4.19.2",
    "node-hid": "^3.1.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=18"
  }
}
