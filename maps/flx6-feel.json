{
  "device": "Pioneer DDJ-FLX6",
  "global": {
    "jog":  { "intervalMs": 10, "rpm": 33.333, "alpha": 0.125, "beta": 0.0039, "scale": 0.004 },
    "enc":  { "step": 0.01, "accel": 0.6 },
    "softTakeoverWindow": 0.04
  },
  "controls": {
    "xfader": { "type": "absolute", "min": 0, "max": 1, "curve": "linear", "deadzone": 0, "soft": true },
    "ch1Gain":{ "type": "absolute", "min": 0, "max": 1.5, "curve": "log", "curveK": 2.4, "soft": true },
    "ch1Hi":  { "type": "absolute", "min": 0, "max": 1, "curve": "s-curve", "curveK": 2.0, "soft": true },
    "filter": { "type": "relative", "step": 0.015, "accel": 0.4, "clamp": [0,1] },
    "browse": { "type": "relative", "step": 1.0, "accel": 0.0, "clamp": [0, 999999] },
    "jog": {
      "type": "jog",
      "scaleOverride": 0.0045,
      "deltaCodec": "relative7",
      "defaultLane": "wheel_side",
      "lanes": {
        "wheel_side": { "directScale": 0.18, "velocityScale": 0.06, "damping": 0.64, "maxVel": 0.16, "motionMode": "nudge" },
        "wheel_side_shifted": { "directScale": 0.14, "velocityScale": 0.05, "damping": 0.6, "maxVel": 0.12, "motionMode": "nudge" },
        "platter_vinyl_on": { "directScale": 0.28, "velocityScale": 0.08, "damping": 0.7, "maxVel": 0.22, "motionMode": "vinyl_platter" },
        "platter_vinyl_off": { "directScale": 0.36, "velocityScale": 0.12, "damping": 0.78, "maxVel": 0.28, "motionMode": "spin" },
        "platter_shifted": { "directScale": 0.24, "velocityScale": 0.07, "damping": 0.66, "maxVel": 0.18, "motionMode": "vinyl_platter" },
        "scratch": { "directScale": 0.62, "velocityScale": 0.015, "damping": 0.34, "maxVel": 0.08, "motionMode": "scratch" },
        "scratch_shifted": { "directScale": 0.46, "velocityScale": 0.012, "damping": 0.3, "maxVel": 0.06, "motionMode": "scratch" },
        "jog_cutter": { "directScale": 0.5, "velocityScale": 0.01, "damping": 0.28, "maxVel": 0.05, "motionMode": "jog_cutter" }
      }
    }
  }
}
